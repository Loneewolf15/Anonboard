rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Anyone can look up a user to send a message
      allow get: if true; 
      allow list: if request.query.limit == 1; 
      
      // Only the owner can create or update their own profile
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      match /messages/{messageId} {
        // Only the owner can read their messages
        allow get, list: if request.auth != null && request.auth.uid == userId;
        
        // Anyone can drop a message (anonymous senders)
        allow create: if true;
        
        // Only the owner can manage reactions or delete messages
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
