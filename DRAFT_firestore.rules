rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Schema Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.createdAt == request.time &&
             (!data.keys().contains('watermark') || (data.watermark is string && data.watermark.size() <= 100));
    }

    function isValidMessage(data, userId) {
      return data.keys().hasAll(['content', 'createdAt', 'recipientUid']) &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 1000 &&
             data.createdAt == request.time &&
             data.recipientUid == userId &&
             (!data.keys().contains('category') || (data.category is string && data.category.size() <= 50)) &&
             (!data.keys().contains('reactions') || (data.reactions is map && data.reactions.size() <= 10));
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isValidId(userId); // Public can see who they are sending to
      allow list: if false; // No directory scraping
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && (
        // Action: Update watermark
        (incoming().diff(existing()).affectedKeys().hasOnly(['watermark']) && incoming().watermark is string && incoming().watermark.size() <= 100) ||
        // Action: Update display name
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) && incoming().displayName is string && incoming().displayName.size() <= 50)
      );
      
      match /messages/{messageId} {
        // Read: Only the recipient can read their messages
        allow get, list: if isOwner(userId);
        
        // Create: Anyone can create if they have a valid recipient
        // We verify the recipient actually exists to prevent orphaned messages
        allow create: if isValidId(messageId) && isValidMessage(incoming(), userId) && exists(/databases/$(database)/documents/users/$(userId));
        
        // Update: Only owner can update (e.g. for reactions)
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['reactions']);
        
        allow delete: if isOwner(userId);
      }
    }
  }
}
